# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/whosrunningusa

# Authentication
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN=7d

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:3000

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@whosrunningusa.com

# AWS S3 (file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=whosrunningusa-uploads

# Sentry Error Monitoring
SENTRY_DSN=

# Stripe Identity (candidate verification)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# External API Keys
OPEN_STATES_API_KEY=
FEC_API_KEY=
CONGRESS_GOV_API_KEY=
VOTE_SMART_API_KEY=

# Admin API key (for automated sync endpoints)
ADMIN_API_KEY=
